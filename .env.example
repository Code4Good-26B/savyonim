# Supabase project used by this app instance
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose this value with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public application URL. Configure the same value as the Supabase Auth Site URL
# and allow APP_URL/onboarding as an Auth redirect URL.
APP_URL=http://localhost:3000

# Production SMTP settings used by the hosted Supabase Auth service.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_ADMIN_EMAIL=no-reply@example.com
SMTP_SENDER_NAME=Savionim

# Safety guard for local development.
# true  -> block POST/PUT/PATCH/DELETE under /api
# false -> allow writes from local app
# If omitted, the app blocks writes by default in development.
BLOCK_API_WRITES=true

# Commbox webhook signature verification secret.
# Must be set in production. A dev fallback is used locally if omitted.
COMMBOX_WEBHOOK_SECRET=dev-only-commbox-secret

# Local mock sender config
MOCK_WEBHOOK_BASE_URL=http://localhost:3000

# Webhook endpoint rate limiting
WEBHOOK_RATE_LIMIT_MAX=60
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# Intake endpoint auth key (Issue #42 / #43)
COMMBOX_INTAKE_API_KEY=dev-commbox-api-key
